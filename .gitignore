# Build outputs
/build
/.cache
build.exe
build.rdi
build.pdb
*.rdi
*.pdb
game.sln
template-starter.rbg
/.vs

# Generated at build time
/sauce/generated.odin
/sauce/generated_shader.odin
atlas.png
font.png
# sokol per-platform C libs produced by sauce/sokol/build_clibs_*.sh
# (Windows DLLs at sauce/sokol/sokol_dll_windows_* stay tracked.)
/sauce/sokol/*/*.a
/sauce/sokol/*/*.so
/sauce/sokol/*/*.o

# Asset workbench scratch
/asset_workbench/fmod/.user
/asset_workbench/fmod/.unsaved
/asset_workbench/fmod/.cache
# Blueprint's placeholder audio source files (~30MB). Restore from a
# blueprint clone if you need to rebuild the banks; will be replaced
# with our own audio later.
/asset_workbench/fmod/Assets/

# Third-party SDKs / tools we don't redistribute.
# See docs/setup.md for how to restore these after cloning.
# FMOD SDK + banks (licensed; users grab it themselves).
/sauce/fmod/
/res/fmod/
# sokol-shdc cross-compiler binaries (~40MB combined; download upstream).
/sokol-shdc-win.exe
/sokol-shdc-mac
/sokol-shdc-linux
